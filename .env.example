# Copy this file to .env and replace with your real key.
GROQ_API_KEY=your_groq_api_key_here

# Primary model (will auto-fallback if decommissioned)
GROQ_MODEL=llama-3.3-70b-versatile

# Fallback models (tried in order if primary is unavailable)
GROQ_FALLBACK_MODELS=llama-3.3-70b-versatile,llama-3.2-90b-vision-preview,gemma-2-9b-it,llama-3.1-8b-instant
